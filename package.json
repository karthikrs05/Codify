    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "nodemailer": "^8.0.7"
  }
}
