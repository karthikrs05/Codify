MONGODB_URI=mongodb://127.0.0.1:27017/codify_arena
# macOS workaround if you see "connect EPERM 127.0.0.1:27017":
# MONGODB_URI=mongodb://%2Ftmp%2Fmongodb-27017.sock/codify_arena
JWT_SECRET=change_me_dev_secret
# Comma-separated list, e.g. http://localhost:5173
# CORS_ORIGIN=
# PORT=8787
# If you change PORT, set the Vite proxy target too:
# VITE_API_TARGET=http://localhost:8787
